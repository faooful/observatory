{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "observatory-osrs-chunks",
  "main": "./chunk-worker.js",
  "compatibility_date": "2026-06-22",
  "workers_dev": true,
  "preview_urls": false,
  "r2_buckets": [
    {
      "binding": "OSRS_CHUNKS",
      "bucket_name": "observatory-osrs-chunks"
    }
  ]
}
